NODE_ENV=development
PORT=3015

# Database
MONGODB_URI=mongodb://localhost:27017/flora
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret
VAULT_MASTER_KEY=your-vault-key
# ENCRYPTION_KEY must be exactly 64 hex characters (32 bytes) for AES-256-GCM encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example: a8d57eb04e6c62c921b26c68577db85cae8473a2c6b7579978cb965ab722da10
ENCRYPTION_KEY=your-encryption-key-32-bytes-hex-string

# Service Discovery
WORKSPACE_URL=http://localhost:4001
CRM_URL=http://localhost:3001
CAPTABLE_URL=http://localhost:3003

# Monolith API Communication
MONOLITH_API_URL=http://localhost:3000
MONOLITH_API_KEY=optional-api-key-for-authentication
MONOLITH_API_TIMEOUT=10000
MONOLITH_API_MAX_RETRIES=3
MONOLITH_API_RETRY_DELAY=1000

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Slack Integration
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:4000/api/integrations/slack/callback

# Google/Gmail Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/gmail/callback

# Zero Data Retention (ZDR) Configuration
# Comma-separated list of ZDR-enabled tenant company IDs
ZDR_TENANT_IDS=
# Comma-separated list of tenants opted into zdr_contracted tier
ZDR_CONTRACTED_TENANT_IDS=
# Artifact TTL for non-ZDR tenants (hours, default 24)
ARTIFACT_TTL_HOURS=24
# Purge job interval (minutes, default 60)
PURGE_INTERVAL_MINUTES=60
# Enable/disable artifact purge scheduling (default true)
ENABLE_SCHEDULED_PURGE=true
# Fail-closed routing mode (default false; ZDR tenants auto-enable)
ROUTING_FAIL_CLOSED=false
# Hard erase enable — MUST remain false until ZDR-EX-1 is signed off
ZDR_HARD_ERASE_ENABLED=false
# HMAC key for signing deletion attestations (defaults to JWT_SECRET)
ZDR_ATTESTATION_KEY=

# Self-Hosted Inference Provider (ZDR-E5-S1)
# Base URL for in-perimeter inference endpoint (vLLM/Ollama/Tabby)
SELF_HOSTED_ENDPOINT=
# Default model name
SELF_HOSTED_MODEL=qwen2.5-coder-32b-instruct
# Optional auth token for the inference endpoint
SELF_HOSTED_API_KEY=
# Request timeout in milliseconds (default 60000)
SELF_HOSTED_TIMEOUT_MS=60000
